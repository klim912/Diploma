# ============================================================
# .env  (розробка — НЕ комітити у git, вже є у .gitignore)
# ============================================================

# Мінімальний рівень логування фронтенду
# Можливі значення: DEBUG | INFO | WARN | ERROR | CRITICAL
# Зміна без перекомпіляції:
#   1. Змінити значення тут → npm run dev перезапустить автоматично
#   2. Або в DevTools: localStorage.setItem('LOG_LEVEL', 'DEBUG') + F5
VITE_LOG_LEVEL=DEBUG

# Версія застосунку (відображається в логах)
VITE_APP_VERSION=0.0.1-dev

# Firebase (вже є у вашому проекті — не змінювати)
# VITE_FIREBASE_API_KEY=...
# VITE_FIREBASE_AUTH_DOMAIN=...
