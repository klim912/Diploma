{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "name": "GameStore — Документація",
  "readme": "README.md",
  "includeVersion": true,
  "skipErrorChecking": true,
  "excludeExternals": true,
  "excludePrivate": false,
  "excludeProtected": false,
  "categorizeByGroup": true,
  "navigationLinks": {
    "GitHub": "https://github.com/klim912/Diploma"
  },
  "exclude": [
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/coverage/**",
    "**/dist/**",
    "**/__mocks__/**"
  ]
}
